/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=(self), usb=(), serial=(), bluetooth=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https:; font-src 'self' data:; media-src 'self' https: blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests

/admin/*
  Cache-Control: no-store, no-cache, must-revalidate

/members/*
  Cache-Control: no-store, no-cache, must-revalidate

/login/*
  Cache-Control: no-store, no-cache, must-revalidate

/register/*
  Cache-Control: no-store, no-cache, must-revalidate

/account-help/*
  Cache-Control: no-store, no-cache, must-revalidate

/functions/api/*
  Cache-Control: no-store, no-cache, must-revalidate
